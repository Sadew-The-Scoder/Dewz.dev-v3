---
// src/components/About.astro
import { SITE } from "../consts/index.js";
import NeonText from "./NeonText";
---

<section
    id="about"
    class="max-w-6xl mx-auto min-h-[calc(100dvh-64px)] scroll-mt-16 relative overflow-hidden flex flex-col justify-center px-4 md:px-8 py-16 text-white border-b border-slate-900/40"
>
    <div
        class="absolute top-1/4 right-0 w-80 h-80 bg-neon-purple/5 rounded-full blur-[120px] pointer-events-none animate-pulse duration-5000"
    >
    </div>

    <div
        class="absolute inset-0 bg-[radial-gradient(#ffffff03_1px,transparent_1px)] bg-size-[24px_24px] pointer-events-none"
    >
    </div>

    <div class="w-full space-y-12 z-10">
        <div class="text-center md:text-left space-y-3">
            <NeonText class="text-3xl md:text-left">About Me</NeonText>
            <p
                class="text-sm md:text-base text-slate-400 max-w-xl mx-auto md:mx-0 leading-relaxed font-mono"
            >
                // A look into who I am and my tech philosophy.
            </p>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start"
        >
            <div class="md:col-span-7 space-y-6">
                <h3
                    class="text-xl md:text-2xl font-bold text-slate-200 tracking-wide font-sans leading-snug"
                >
                    {SITE.tagline}
                </h3>

                <div
                    class="space-y-4 text-slate-400 text-sm md:text-base leading-relaxed font-normal"
                >
                    {SITE.bio.map((paragraph) => <p>{paragraph}</p>)}
                </div>
            </div>

            <div
                class="md:col-span-5 bg-slate-900/20 border border-slate-900/80 p-6 rounded-2xl backdrop-blur-sm relative group hover:border-neon-purple/30 transition-all duration-300"
            >
                <div
                    class="flex items-center gap-2 pb-4 border-b border-slate-800/40 mb-4"
                >
                    <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
                    <span class="text-xs font-mono text-slate-500 ml-2"
                        >status.sh</span
                    >
                </div>

                <div class="space-y-4 font-mono text-xs md:text-sm">
                    <div>
                        <span class="text-neon-pink">dewz@workspace</span><span
                            class="text-slate-400">:~$</span
                        >
                        <span class="text-slate-200">cat current_status.md</span
                        >
                    </div>
                    <div
                        class="text-slate-400 pl-4 border-l border-slate-800 leading-relaxed"
                    >
                        {SITE.status}
                    </div>

                    <div class="pt-2">
                        <span class="text-neon-pink">dewz@workspace</span><span
                            class="text-slate-400">:~$</span
                        >
                        <span class="text-slate-200">echo $ROLE</span>
                    </div>
                    <div class="text-neon-yellow pl-4">
                        "{SITE.role}"
                    </div>

                    <div class="pt-2">
                        <span class="text-neon-pink">dewz@workspace</span><span
                            class="text-slate-400">:~$</span
                        >
                        <span class="text-slate-200">location</span>
                    </div>
                    <div class="text-slate-400 pl-4">
                        "Monaragala, Sri Lanka"
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
